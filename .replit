modules = ["nodejs-20", "python-3.11"]
[nix]
channel = "stable-25_05"
packages = ["unzip"]

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Trinet Layer Website"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend API"

[[workflows.workflow]]
name = "Trinet Layer Website"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd \"Trinet Layer Code/Trinet/Trinet-Layer/Trinet_layer\" && npm start"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Backend API"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd \"Trinet Layer Code/Trinet/Trinet-Layer\" && python -m uvicorn cve_scanner.main:app --host 0.0.0.0 --port 8000"
waitForPort = 8000

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8000
externalPort = 8000

[deployment]
deploymentTarget = "autoscale"
run = ["python", "-m", "uvicorn", "cve_scanner.main:app", "--host", "0.0.0.0", "--port", "5000", "--app-dir", "Trinet Layer Code/Trinet/Trinet-Layer"]
build = ["npm", "--prefix", "Trinet Layer Code/Trinet/Trinet-Layer/Trinet_layer", "run", "build"]

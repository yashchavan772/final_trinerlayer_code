modules = ["nodejs-20", "python-3.11"]
[nix]
channel = "stable-25_05"
packages = ["unzip", "nuclei"]

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Trinet Layer Website"

[[workflows.workflow]]
name = "Trinet Layer Website"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd \"TrinetLayerCode/Trinet/Trinet-Layer/Trinet_layer\" && npm start"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5002
externalPort = 3001

[[ports]]
localPort = 8000
externalPort = 8000

[deployment]
deploymentTarget = "static"
run = ["echo", "static site"]
build = ["bash", "-c", "cd TrinetLayerCode/Trinet/Trinet-Layer/Trinet_layer && npm run build"]
publicDir = "TrinetLayerCode/Trinet/Trinet-Layer/Trinet_layer/build"
